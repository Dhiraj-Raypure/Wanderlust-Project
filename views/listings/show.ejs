<% layout('/layouts/boilerplate') -%>
<script>
    const mapToken = "<%= process.env.MAP_TOKEN %>";
    const listing = <%- JSON.stringify(list) %>;
</script>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <h3 class="card-title fw-bold mb-3"><%= list.title %></h3>
            <div class="card shadow-sm rounded-4 listing-card">
                <img 
                    src="<%= list.image.url %>" 
                    class="card-img-top rounded-top-4" 
                    alt="Listing Image"
                    style="height: 350px; object-fit: cover;"
                />
                <div class="card-owner d-flex align-items-center gap-2 px-4 py-2" 
                    style="background: linear-gradient(135deg, #f8f9fa, #e9ecef); border-bottom: 1px solid rgba(0,0,0,0.08);">
                    <i class="fa-solid fa-user-circle" style="color: #6c757d; font-size: 1rem;"></i>
                    <span style="font-size: 0.85rem; color: #6c757d; font-weight: 500; letter-spacing: 0.3px;">
                        Owned by <strong style="color: #343a40;"><%= list.owner.username %></strong>
                    </span>
                </div>

                <div class="card-body p-4">
                    
                    <p class="card-text text-muted"><%= list.description %></p> 
                    
                    <hr/>
                    <p class="card-text">
                        <i class="fa-solid fa-indian-rupee-sign"></i>
                        <span class="fw-bold fs-5"><%= list.price.toLocaleString("en-IN") %></span>
                        <span class="text-muted">/ night</span>
                    </p>
                    <hr/>
                    <p class="card-text">
                        <i class="fa-solid fa-location-dot"></i>
                        <%= list.location %>, <%= list.country %>
                    </p>

                </div>

                <% if(currUser && currUser._id.equals(list.owner._id)) { %>

                    <div class="card-footer d-flex justify-content-end gap-2 p-3">
                    <a href="/listings/<%= list._id %>/edit" class="btn btn-outline-dark">
                        <i class="fa-solid fa-pen"></i> Edit
                    </a>
                    <form action="/listings/<%= list._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-danger">
                            <i class="fa-solid fa-trash"></i> Delete
                        </button>
                    </form>
                    </div>                   
                <% } %>

                <hr>
                <% if(currUser){ %> 
                    <div>
                        <h4>Leave a Review </h4>
                        <form action="/listings/<%= list._id %>/reviews" method = "POST" class="form-control needs-validation" novalidate >
                            <!-- <div class ="mb-3 mt-3">
                                <label for ="rating" class="form-label">Rating</label>
                                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
                            </div> -->
                            <div class ="mb-3 mt-3">
                                <label for ="rating" class="form-label">Rating</label>
                                <fieldset class="starability-growRotate" id = "rating">
                                    <input type="radio" 
                                        id="second-no-rate" 
                                        class="input-no-rate" 
                                        name="review[rating]" 
                                        value="0" 
                                        checked 
                                        aria-label="No rating" 
                                    />
                                    <input type="radio" id="second-rate1" name="review[rating]" value="1" />
                                    <label for="second-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="second-rate2" name="review[rating]" value="2" />
                                    <label for="second-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="second-rate3" name="review[rating]" value="3" />
                                    <label for="second-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="second-rate4" name="review[rating]" value="4" />
                                    <label for="second-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="second-rate5" name="review[rating]" value="5" />
                                    <label for="second-rate5" title="Amazing">5 stars</label>
                                </fieldset> 
                            </div>
                            <div class ="mb-3 mt-3">
                                <label for="comment" class="form-label">Comment</label>
                                <textarea id = "comment" name="review[comment]" cols="50" rows="5" class="form-control" required></textarea>
                                <div class="valid-feedback">
                                    Thanks For Feedback
                                </div>
                                <div class="invalid-feedback">
                                    Please give Feedback
                                </div>
                            </div>
                            <button class="btn btn-outline-dark">Submit</button>
                        </form>
                    </div>
                <% } %>
            </div>

            <% if(list.reviews.length != 0) { %>

                <p><b>All Reviews</b></p>
                <div class="row row-cols-1 row-cols-md-2 g-3 mb-3">
                    <% for(review of list.reviews){ %>
                        <div class="col">
                        <div class="card h-100">
                            <div class="card-body p-4">
                                <h5 class="card-title"> @<%=review.owner.username %></h5>
                                <p class="starability-result card-text" data-rating="<%= review.rating %>">
                                <p class="card-text"><%= review.comment %></p>
                                    Rated: <%= review.rating %>      stars
                                </p>
                                <% if(currUser && review.owner._id.equals(currUser._id)){ %>
                                    <form method = "POST" action="/listings/<%= list._id %>/reviews/<%= review._id %>?_method=DELETE">
                                        <button class="btn btn-dark btn-sm">Delete</button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                        </div>
                    <% } %>
                </div>
            <% } %>
            <div>
                <h3>Where you'll be : </h3>
                <div id="map"></div>
            </div>
        </div>
    </div>
</div>
<script src = "/js/map.js"></script>