<style>
  .search-form{
      width: 450px;
  }

  .search-input{
      min-width: 350px;
  }
  .search-btn{
    width : 4rem;
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light sticky-top border-bottom">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
        <div class="navbar-nav">
            <a class="nav-link" href="/listings">Explore</a>
        </div>

        <form action = "/listings/search" method="GET" class="d-flex mx-3 search-form">
          <input
              class="form-control rounded-pill me-2 search-input"
              type="search"
              placeholder="Search destinations"
              name="search"
          >
          <button class="btn btn-danger rounded-pill px-3 search-btn" type="submit">
              <i class="fa-solid fa-magnifying-glass"></i>
          </button>
      </form>

        <div class="navbar-nav ms-auto">
            <a class="nav-link" href="/listings/new">Become a host</a>
            <% if(!currUser) { %>
              <a class="nav-link " aria-current="page" href="/signup"><b>Sign up</b></a>
              <a class="nav-link" href="/login"><b>Log in</b></a>
            <% } %>
            <% if(currUser) { %>
              <b><a class="nav-link" href="/logout">Log out</a></b>
            <% } %>
        </div>
    </div>
  </div>
</nav>